# Morning Dew backend — copy this file to .env and fill in what you have.
# Every section degrades to a clearly-labelled placeholder card if its
# variables are missing — nothing here is required for the app to run.

# Port the backend listens on (serves the PWA + /api/* routes).
PORT=8787

# --- Calendar (iCloud .ics subscription) ---
# In Calendar.app on Mac: right-click your calendar -> Share Calendar... ->
# Public Calendar -> copy the link, then change "webcal://" to "https://".
# On iCloud.com: Calendar -> hover the calendar -> ... -> Public Calendar.
# Multiple calendars? Separate their links with commas — all of them get
# fetched and merged into one "Next 48 hours" feed.
ICLOUD_ICS_URL=

# --- Reminders ---
# Apple Reminders has no public .ics export API. The supported no-credential
# path: in Reminders.app, convert (or mirror) the list you want into an iCloud
# *Calendar* shared as a public link (same steps as above), and point this at
# that link. See DECISIONS.md for why this approach was chosen.
REMINDERS_ICS_URL=

# --- Gmail (OAuth refresh token flow) ---
# 1. Create a project at https://console.cloud.google.com/, enable the Gmail API.
# 2. Create OAuth client credentials (type: Desktop app) -> get GOOGLE_CLIENT_ID
#    and GOOGLE_CLIENT_SECRET.
# 3. Run the OAuth consent flow once (e.g. via Google's OAuth Playground at
#    https://developers.google.com/oauthplayground, using your own client
#    ID/secret under the gear icon, scope https://www.googleapis.com/auth/gmail.readonly)
#    to obtain a refresh token -> GOOGLE_REFRESH_TOKEN.
# Full walkthrough in README.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Outlook / Microsoft 365 (Graph API, OAuth refresh token flow) ---
# Covers Outlook Calendar, Outlook Tasks/To Do (used as the Outlook equivalent
# of Reminders — Microsoft has no separate "Reminders" API), and Outlook Mail.
# When set alongside ICLOUD_ICS_URL / REMINDERS_ICS_URL / GOOGLE_*, results from
# both providers are merged into the same calendar/reminders/email cards.
# 1. Register an app at https://portal.azure.com/ -> Azure Active Directory ->
#    App registrations -> New registration. Note the Application (client) ID
#    -> MS_CLIENT_ID, and the Directory (tenant) ID -> MS_TENANT_ID (use
#    "common" instead if the app supports personal Microsoft accounts).
# 2. Certificates & secrets -> New client secret -> MS_CLIENT_SECRET.
# 3. API permissions -> Add a permission -> Microsoft Graph -> Delegated:
#    Calendars.Read, Tasks.Read, Mail.Read, offline_access. Grant admin consent
#    if required by your tenant.
# 4. Authentication -> Add platform -> Mobile and desktop applications ->
#    add redirect URI https://login.microsoftonline.com/common/oauth2/nativeclient.
# 5. Run the authorization-code flow once to get a refresh token (Microsoft has
#    no hosted "OAuth Playground" equivalent to Google's, so this is a manual
#    browser + curl step — full walkthrough in README.md) -> MS_REFRESH_TOKEN.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=
MS_TENANT_ID=
